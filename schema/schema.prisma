// PA CROP Services — Prisma Schema
// This schema matches the actual Neon Postgres tables queried by api/services/db.js.
// All column names use snake_case to match raw SQL in db.js.
// Run: npx prisma migrate dev --name init
//
// IMPORTANT: db.js uses raw SQL via @neondatabase/serverless, not Prisma Client.
// This schema exists for migration generation and documentation only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Organizations ──────────────────────────────────────────

model organizations {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legal_name               String
  display_name             String?
  entity_type              String   @default("domestic_llc")
  jurisdiction             String   @default("PA")
  dos_number               String?
  formation_date           String?
  entity_status            String   @default("pending_verification")
  risk_level               String   @default("unknown")
  principal_address        Json?    @default("{}")
  registered_office_address Json?   @default("{}")
  partner_id               String?  @db.Uuid
  metadata                 Json?    @default("{}")
  created_at               DateTime @default(now())
  updated_at               DateTime @default(now()) @updatedAt

  clients       clients[]
  obligations   obligations[]
  documents     documents[]
  notifications notifications[]
}

// ── Clients ────────────────────────────────────────────────

model clients {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id       String?  @db.Uuid
  owner_name            String?
  email                 String   @unique
  phone                 String?
  plan_code             String   @default("compliance_only")
  billing_status        String   @default("inactive")
  onboarding_status     String   @default("not_started")
  referral_code         String?
  referred_by_client_id String?  @db.Uuid
  communication_prefs   Json?    @default("{}")
  metadata              Json?    @default("{}")
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now()) @updatedAt

  organization    organizations? @relation(fields: [organization_id], references: [id])
  billing_account billing_accounts?
  notifications   notifications[]
}

// ── Obligations ────────────────────────────────────────────

model obligations {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id   String   @db.Uuid
  rule_id           String?  @db.Uuid
  rule_version      Int?
  obligation_type   String   @default("annual_report")
  obligation_status String   @default("detected")
  jurisdiction      String   @default("PA")
  due_date          DateTime?
  fee_usd           Decimal? @db.Decimal(10, 2)
  filing_method     String?
  source_reason     String?
  metadata          Json?    @default("{}")
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  organization organizations @relation(fields: [organization_id], references: [id])
  documents    documents[]
}

// ── Documents ──────────────────────────────────────────────

model documents {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id    String?  @db.Uuid
  obligation_id      String?  @db.Uuid
  document_type      String   @default("general_mail")
  source_channel     String?
  filename           String?
  mime_type          String?
  storage_key        String?
  storage_url        String?
  urgency            String   @default("normal")
  review_status      String   @default("pending")
  extracted_text     String?
  extracted_entities Json?    @default("[]")
  classifier_version String?
  processed_at       DateTime?
  received_at        DateTime @default(now())
  metadata           Json?    @default("{}")
  created_at         DateTime @default(now())

  organization organizations? @relation(fields: [organization_id], references: [id])
  obligation   obligations?   @relation(fields: [obligation_id], references: [id])
}

// ── Notifications ──────────────────────────────────────────

model notifications {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id     String?  @db.Uuid
  obligation_id       String?  @db.Uuid
  client_id           String?  @db.Uuid
  notification_type   String?
  channel             String   @default("email")
  template_id         String?
  scheduled_for       DateTime?
  delivery_status     String   @default("scheduled")
  sent_at             DateTime?
  retry_count         Int      @default(0)
  provider_message_id String?
  metadata            Json?    @default("{}")
  created_at          DateTime @default(now())

  organization organizations? @relation(fields: [organization_id], references: [id])
  client       clients?       @relation(fields: [client_id], references: [id])
}

// ── AI Conversations ───────────────────────────────────────

model ai_conversations {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id  String?  @db.Uuid
  client_id        String?  @db.Uuid
  channel          String?
  user_message     String?
  assistant_answer String?
  source_refs      Json?    @default("[]")
  confidence_score Float?
  escalation_flag  Boolean  @default(false)
  moderation_flag  Boolean  @default(false)
  model_name       String?
  created_at       DateTime @default(now())
}

// ── Audit Events ───────────────────────────────────────────

model audit_events {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_type     String?
  actor_id       String?
  event_type     String
  target_type    String?
  target_id      String?
  before_json    Json?
  after_json     Json?
  reason         String?
  correlation_id String?
  created_at     DateTime @default(now())
}

// ── Workflow Jobs ──────────────────────────────────────────

model workflow_jobs {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_type       String
  job_status     String   @default("queued")
  payload        Json?    @default("{}")
  max_attempts   Int      @default(5)
  attempt_count  Int      @default(0)
  last_error     String?
  scheduled_for  DateTime?
  completed_at   DateTime?
  correlation_id String?
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
}

// ── Billing Accounts ───────────────────────────────────────

model billing_accounts {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id               String   @unique @db.Uuid
  stripe_customer_id      String?
  stripe_subscription_id  String?
  current_period_end      DateTime?
  billing_status          String   @default("inactive")
  plan_code               String   @default("compliance_only")
  entitlements            Json?    @default("{}")
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now()) @updatedAt

  client clients @relation(fields: [client_id], references: [id])
}

// ── Rules ──────────────────────────────────────────────────

model rules {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type     String
  jurisdiction    String   @default("PA")
  obligation_type String   @default("annual_report")
  version         Int      @default(1)
  is_active       Boolean  @default(false)
  due_month       Int?
  due_day         Int?
  fee_usd         Decimal? @db.Decimal(10, 2)
  filing_method   String?
  enforcement     Json?    @default("{}")
  source_citation String?
  metadata        Json?    @default("{}")
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
}

// ── Referrals ──────────────────────────────────────────────

model referrals {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrer_client_id  String   @db.Uuid
  referred_email      String
  referral_status     String   @default("invited")
  metadata            Json?    @default("{}")
  created_at          DateTime @default(now())
}

// ── Partners ───────────────────────────────────────────────

model partners {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  email           String   @unique
  partner_type    String   @default("cpa")
  commission_rate Decimal? @db.Decimal(5, 2)
  is_active       Boolean  @default(true)
  metadata        Json?    @default("{}")
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
}
