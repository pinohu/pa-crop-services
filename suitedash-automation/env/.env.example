# PA CROP Services — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit the .env file to GitHub

# ============================================================
# SUITEDASH
# ============================================================
SUITEDASH_API_ID=REPLACE_ME
SUITEDASH_PUBLIC_ID=REPLACE_ME
SUITEDASH_API_SECRET=REPLACE_ME
SUITEDASH_SECRET_KEY=REPLACE_ME
SUITEDASH_BASE_URL=https://app.suitedash.com/secure-api/v1
SUITEDASH_PORTAL_URL=REPLACE_ME

# ============================================================
# AITABLE
# ============================================================
AITABLE_API_KEY=REPLACE_ME
AITABLE_BASE_URL=https://api.aitable.ai
AITABLE_CLIENTS_SHEET=REPLACE_ME
AITABLE_CLIENTS_TABLE=REPLACE_ME
AITABLE_ENGAGEMENT_TABLE=REPLACE_ME
AITABLE_LEAD_SCORES_TABLE=REPLACE_ME
AITABLE_COMMS_LOG_TABLE=REPLACE_ME
AITABLE_WORKFLOW_STATE_TABLE=REPLACE_ME
AITABLE_DLQ_TABLE=REPLACE_ME
AITABLE_ANALYTICS_TABLE=REPLACE_ME
AITABLE_AUDIT_LOG_TABLE=REPLACE_ME
AITABLE_EVENT_LOG_TABLE=REPLACE_ME
AITABLE_SYSTEM_CONFIG_TABLE=REPLACE_ME
AITABLE_SYSTEM_ACTIVE_RECORD=REPLACE_ME

# ============================================================
# STRIPE
# ============================================================
STRIPE_PUBLISHABLE_KEY=REPLACE_ME
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME

# ============================================================
# EMAIL — EMAILIT (transactional sending via SMTP)
# Get credentials: Emailit dashboard → Credentials → Create SMTP credential
# ============================================================
SMTP_HOST=smtp.emailit.com
SMTP_PORT=25
SMTP_USER=REPLACE_ME_WITH_EMAILIT_SMTP_USERNAME
SMTP_PASS=REPLACE_ME_WITH_EMAILIT_SMTP_PASSWORD
SMTP_FROM_EMAIL=hello@pacropservices.com

# ============================================================
# EMAIL — SUITEDASH (sequences + client communications)
# Built into SuiteDash — no separate credentials needed
# ============================================================

# ============================================================
# EMAIL — ACUMBAMAIL or TINYMAIL (marketing campaigns)
# Use for bulk newsletters and announcements
# ============================================================
ACUMBAMAIL_API_KEY=REPLACE_ME

# ============================================================
# N8N
# ============================================================
N8N_WEBHOOK_BASE=https://n8n.audreysplace.place/webhook

# ============================================================
# PAPERLESS-NGX
# ============================================================
PAPERLESS_URL=http://localhost:8000
PAPERLESS_API_TOKEN=REPLACE_ME

# ============================================================
# ANTHROPIC (for OpenClaw agents)
# ============================================================
ANTHROPIC_API_KEY=REPLACE_ME
