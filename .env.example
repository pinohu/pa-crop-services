# PA CROP Services — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it's gitignored.

# ── AI (Groq) ──
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Authentication ──
ADMIN_SECRET_KEY=               # Strong random string for admin API auth
JWT_SECRET=                     # Used by jose for JWT signing
DEMO_ACCESS_CODE=               # Demo account code (non-prod only, leave empty to disable)
API_KEY_HASH_SECRET=            # Secret for hashing API keys (defaults to JWT_SECRET if unset)
SECRETS_MASTER_KEY=             # 32-byte base64 or 64-char hex; encrypts hosting_password and other JSONB secrets at rest. Generate: openssl rand -base64 32

# ── Twilio (voice/SMS webhook signature verification) ──
TWILIO_AUTH_TOKEN=              # Required for /api/voice + /api/voice-recording signature verification

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Per-plan price IDs (used by /api/billing/checkout) — name matches services/plans.js
STRIPE_PRICE_COMPLIANCE_ONLY=
STRIPE_PRICE_BUSINESS_STARTER=
STRIPE_PRICE_BUSINESS_PRO=
STRIPE_PRICE_BUSINESS_EMPIRE=
# Legacy Payment Link URLs (used as fallback in pricing CTAs until /api/billing/checkout is fully wired)
STRIPE_LINK_COMPLIANCE=
STRIPE_LINK_STARTER=
STRIPE_LINK_PRO=
STRIPE_LINK_EMPIRE=

# ── SuiteDash CRM ──
SUITEDASH_PUBLIC_ID=
SUITEDASH_SECRET_KEY=

# ── Upstash Redis (rate limiting + DB) ──
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Neon Postgres (if using) ──
DATABASE_URL=postgresql://xxxx

# ── 20i Hosting ──
TWENTY_I_GENERAL=
TWENTY_I_TOKEN=
TWENTY_I_RESELLER_ID=

# ── Email (Emailit) ──
EMAILIT_API_KEY=

# ── Email Marketing (Acumbamail) ──
ACUMBAMAIL_API_KEY=

# ── Document Generation (Documentero) ──
DOCUMENTERO_API_KEY=

# ── Seed Data (for admin cleanup/reset) ──
SEED_CLIENT_EMAIL=
SEED_CLIENT_NAME=
SEED_ORG_NAME=PA Registered Office Services, LLC
SEED_ORG_DISPLAY=PA CROP Services
SEED_DOS_NUMBER=
SEED_CLIENT_PHONE=

# ── n8n Automation ──
N8N_WEBHOOK_URL=https://n8n.audreysplace.place/webhook
N8N_HEALTH_URL=https://n8n.audreysplace.place/healthz

# ── GitHub (for push.py) ──
GITHUB_TOKEN=
