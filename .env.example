# PA CROP Services — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it's gitignored.

# ── AI (Groq) ──
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Authentication ──
ADMIN_SECRET_KEY=               # Strong random string for admin API auth (header X-Admin-Key)
JWT_SECRET=                     # Used by jose for JWT signing
DEMO_ACCESS_CODE=               # Demo account code (non-prod only, leave empty to disable)
SECRETS_MASTER_KEY=             # 32-byte base64 or 64-char hex; encrypts hosting_password and other JSONB secrets at rest. Generate: openssl rand -base64 32

# ── Ops alerts ──
ADMIN_ALERT_EMAIL=hello@pacropservices.com  # Where ops/Ike notifications get sent (defaults to hello@pacropservices.com if unset)

# ── Registered Office (used by services/twentyi.js for domain-registrar contact) ──
# Defaults to PA Registered Office Services, LLC's Erie address; override only if changing.
REGISTERED_OFFICE_STREET=924 W 23rd St
REGISTERED_OFFICE_CITY=Erie
REGISTERED_OFFICE_STATE=PA
REGISTERED_OFFICE_ZIP=16502
REGISTERED_OFFICE_COUNTRY=US

# ── Twilio (currently unused — voice agent runs on Insighto, not Twilio) ──
# Set if you ever wire /api/voice or /api/voice-recording into a real Twilio number.
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_PHONE=

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Per-plan price IDs (used by /api/billing/checkout) — name matches services/plans.js
STRIPE_PRICE_COMPLIANCE_ONLY=
STRIPE_PRICE_BUSINESS_STARTER=
STRIPE_PRICE_BUSINESS_PRO=
STRIPE_PRICE_BUSINESS_EMPIRE=
# Legacy Payment Link URLs (used as fallback in pricing CTAs until /api/billing/checkout is fully wired)
STRIPE_LINK_COMPLIANCE=
STRIPE_LINK_STARTER=
STRIPE_LINK_PRO=
STRIPE_LINK_EMPIRE=

# ── SuiteDash CRM ──
SUITEDASH_PUBLIC_ID=
SUITEDASH_SECRET_KEY=

# ── Upstash Redis (rate limiting + DB) ──
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Neon Postgres (if using) ──
DATABASE_URL=postgresql://xxxx

# ── 20i Hosting ──
TWENTY_I_GENERAL=
TWENTY_I_TOKEN=
TWENTY_I_RESELLER_ID=

# ── Email (Emailit) ──
EMAILIT_API_KEY=

# ── Email Marketing (Acumbamail) ──
ACUMBAMAIL_API_KEY=

# ── Document Generation (Documentero) ──
# Required for /api/generate-agreement to return PDFs (otherwise endpoint returns
# HTML-only fallback, which provision.js Step 7 surfaces as a warning).
DOCUMENTERO_API_KEY=

# ── SMS (SMS-iT) ──
SMSIT_API_KEY=                  # Required by /api/sms — primary SMS provider

# ── Booking (Trafft) ──
TRAFFT_CLIENT_ID=               # Public client id for the Trafft booking widget; required by /api/webinar-scheduler

# ── Content / video / AI extras (feature gates — endpoints early-return when unset) ──
BRIZY_API_KEY=                  # Used by /api/website-builder Brizy integration
CASTMAGIC_API_KEY=              # Used by /api/podcast-generate
FLIKI_API_KEY=                  # Used by /api/video-generate
VADOO_API_KEY=                  # Used by /api/video-generate (alternate provider)

# ── Seed Data (for admin cleanup/reset) ──
SEED_CLIENT_EMAIL=
SEED_CLIENT_NAME=
SEED_ORG_NAME=PA Registered Office Services, LLC
SEED_ORG_DISPLAY=PA CROP Services
SEED_DOS_NUMBER=
SEED_CLIENT_PHONE=

# ── n8n Automation ──
N8N_WEBHOOK_URL=https://n8n.audreysplace.place/webhook
N8N_HEALTH_URL=https://n8n.audreysplace.place/healthz

# ── GitHub (for push.py) ──
GITHUB_TOKEN=
